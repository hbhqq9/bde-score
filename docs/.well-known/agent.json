{
  "name": "BDE Score",
  "description": "AI Agent trust evaluation and EU AI Act compliance assessment. Provides reliability scoring, compliance checking, and trust badges for MCP servers and AI agents. Also offers multi-market stock BDE scoring.",
  "version": "1.0.1",
  "capabilities": {
    "trust_evaluation": {
      "description": "Evaluate the reliability and trustworthiness of AI agents and MCP servers",
      "input": {
        "type": "url",
        "description": "MCP endpoint URL to evaluate"
      },
      "output": {
        "type": "score",
        "range": [
          0,
          100
        ],
        "grade": "A-F"
      }
    },
    "compliance_check": {
      "description": "Automated EU AI Act Article 50 compliance assessment",
      "input": {
        "type": "url",
        "description": "MCP endpoint URL to check"
      },
      "output": {
        "type": "report",
        "checks": 10,
        "max_score": 100
      }
    },
    "stock_analysis": {
      "description": "Multi-market stock analysis with BDE scoring system",
      "markets": [
        "US",
        "HK",
        "A-share"
      ],
      "factors": [
        "momentum",
        "mean_reversion",
        "volume",
        "volatility",
        "trend"
      ]
    }
  },
  "endpoints": {
    "api": "https://thinks-discussions-proof-dec.trycloudflare.com",
    "mcp": "https://generators-computation-picked-emily.trycloudflare.com/mcp",
    "compliance_check": "https://thinks-discussions-proof-dec.trycloudflare.com/compliance-check",
    "x402_pay_info": "https://thinks-discussions-proof-dec.trycloudflare.com/pay/info"
  },
  "authentication": {
    "type": "api_key",
    "free_tier": "3 queries/day",
    "micropayment": "x402 $0.01/query USDC on Base"
  },
  "documentation": "https://github.com/hbhqq9/bde-score",
  "discovery": {
    "mcp": "https://hbhqq9.github.io/bde-score/.well-known/mcp.json",
    "a2a": "https://hbhqq9.github.io/bde-score/.well-known/agent.json",
    "openapi": "https://hbhqq9.github.io/bde-score/openapi.json"
  },
