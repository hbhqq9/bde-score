{
  "name": "BDE Score Agent",
  "description": "AI-powered multi-market stock analysis agent providing quantitative BDE scores (0-100) for US, HK, and CN A-share markets. Covers momentum, volatility, value, quality, and ESG factors.",
  "version": "1.0.0",
  "protocol": "a2a",
  "capabilities": {
    "tools": [
      {
        "id": "bde-score-analysis",
        "name": "BDE Score Analysis",
        "description": "Get comprehensive BDE score analysis for stocks across US/HK/CN markets",
        "inputSchema": {
          "type": "object",
          "properties": {
            "market": {
              "type": "string",
              "enum": [
                "US",
                "HK",
                "A",
                "ALL"
              ]
            },
            "min_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          }
        }
      },
      {
        "id": "stock-comparison",
        "name": "Cross-market Stock Comparison",
        "description": "Compare the same company's BDE scores across US, HK, and CN markets"
      },
      {
        "id": "esg-analysis",
        "name": "ESG Analysis",
        "description": "Get ESG analysis derived from quantitative factors"
      }
    ]
  },
  "endpoints": {
